# Google Maps API Key for address autocomplete
# Get your key from: https://console.cloud.google.com/
# Allow these referrers in Google Cloud for local/non-prod maps:
# http://localhost:*, http://127.0.0.1:*, https://dev.appquilar.com/*, plus staging/production domains.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
VITE_GOOGLE_MAPS_MAP_ID=your_google_maps_map_id_here

# Landing-only mode.
# true/1/yes/on => app redirects to VITE_LANDING_ENTRY and does not mount the platform shell.
VITE_LANDING_ONLY_MODE=false
VITE_LANDING_ENTRY=/landing/index.html
VITE_MAILPIT_URL=http://localhost:8025
